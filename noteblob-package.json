{
  "apiVersion": "1",
  "id": "com.noteblob.plugins",
  "name": "NoteBlob Official Plugins",
  "version": "0.1.0",
  "plugins": [
    {
      "id": "chart",
      "name": "Chart.js",
      "description": "Render Chart.js charts from a ```chart fence.",
      "source": "dist/chart",
      "extension": {
        "id": "note-preview.node",
        "entry": "main.js",
        "node": "codeBlock",
        "languages": ["chart"]
      }
    },
    {
      "id": "prism",
      "name": "Prism",
      "description": "Syntax highlighting for fenced code blocks.",
      "source": "dist/highlight",
      "extension": {
        "id": "note-preview.node",
        "entry": "main.js",
        "node": "codeBlock",
        "languages": [
          "javascript",
          "typescript",
          "python",
          "css",
          "json",
          "bash",
          "swift"
        ]
      }
    },
    {
      "id": "mermaid",
      "name": "Mermaid",
      "description": "Render mermaid diagrams in the preview.",
      "source": "dist/mermaid",
      "extension": {
        "id": "note-preview.node",
        "entry": "main.js",
        "node": "codeBlock",
        "languages": ["mermaid"]
      }
    },
    {
      "id": "pdf",
      "name": "PDF",
      "description": "Preview PDF files.",
      "source": "dist/pdf",
      "extension": {
        "id": "file-preview.document",
        "entry": "main.js",
        "fileExtensions": ["pdf"]
      }
    }
  ]
}
